{
  "name": "couple-map-miniprogram",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "build:miniprogram": "tsc",
    "typecheck": "tsc --noEmit",
    "check:cloud": "find cloudfunctions -name '*.js' -print -exec node --check {} \\;",
    "check:json": "find . -name '*.json' -not -path './.git/*' -not -path './node_modules/*' -not -path './.worktrees/*' -print -exec node -e \"JSON.parse(require('fs').readFileSync(process.argv[1], 'utf8'))\" {} \\;",
    "check:markers": "node scripts/check-markers.js",
    "verify:v100": "node scripts/verify-v100-photo-order.js && node scripts/verify-v100-profile-stats.js"
  },
  "devDependencies": {
    "miniprogram-api-typings": "^4.0.8",
    "typescript": "^5.8.3"
  }
}
