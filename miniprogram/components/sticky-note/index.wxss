.note {
  position: relative;
  min-height: 220rpx;
  padding: 34rpx 24rpx 24rpx;
  border-radius: 16rpx;
  box-shadow: 0 10rpx 24rpx rgba(91, 62, 44, 0.12);
}

.yellow {
  background: #ffe8a6;
}

.pink {
  background: #f9c5cd;
}

.green {
  background: #d7ead2;
}

.blue {
  background: #c9e3f3;
}

.tape {
  position: absolute;
  top: -10rpx;
  left: 50%;
  width: 80rpx;
  height: 28rpx;
  margin-left: -40rpx;
  border-radius: 4rpx;
  background: rgba(255, 253, 249, 0.45);
  transform: rotate(-4deg);
}

.photo {
  width: 100%;
  height: 138rpx;
  border-radius: 12rpx;
  margin-bottom: 14rpx;
}

.text {
  color: #5b4034;
  font-size: 28rpx;
  line-height: 1.45;
  white-space: pre-wrap;
}
