.map-page {
  position: relative;
  min-height: 100vh;
  background: #f8f1ea;
}

.topbar {
  position: absolute;
  z-index: 2;
  top: 22rpx;
  left: 24rpx;
  right: 24rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 18rpx 22rpx;
  border-radius: 20rpx;
  background: rgba(255, 253, 249, 0.92);
  box-shadow: 0 10rpx 28rpx rgba(91, 62, 44, 0.14);
}

.title {
  color: #4f3b31;
  font-size: 30rpx;
  font-weight: 700;
}

.filter {
  color: #8b7468;
  font-size: 24rpx;
}

.map {
  width: 100%;
  height: 100vh;
}

.floating-add {
  position: absolute;
  right: 34rpx;
  bottom: 260rpx;
  z-index: 3;
  width: 92rpx;
  height: 92rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #ff6f65, #e9433d);
  color: #fff;
  font-size: 58rpx;
  line-height: 86rpx;
  text-align: center;
  box-shadow: 0 12rpx 28rpx rgba(233, 75, 67, 0.28);
}

.bottom {
  position: absolute;
  left: 24rpx;
  right: 24rpx;
  bottom: 28rpx;
  z-index: 3;
}

.recent {
  padding: 22rpx;
}

.recent-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 18rpx;
}

.count {
  color: #a68b7d;
  font-size: 24rpx;
}

.place-scroll {
  white-space: nowrap;
}

.scroll-row {
  display: flex;
  gap: 18rpx;
}

.mini-card {
  display: inline-flex;
  width: 170rpx;
  flex-direction: column;
}

.mini-img {
  width: 170rpx;
  height: 120rpx;
  border-radius: 16rpx;
  background: #ead9cc;
}

.mini-empty {
  display: flex;
  align-items: center;
  justify-content: center;
  color: #e94b43;
  font-size: 42rpx;
}

.mini-name {
  overflow: hidden;
  margin-top: 10rpx;
  color: #5b4034;
  font-size: 24rpx;
  text-overflow: ellipsis;
  white-space: nowrap;
}
