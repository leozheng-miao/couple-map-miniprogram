.header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.filter {
  padding: 12rpx 20rpx;
  border-radius: 999rpx;
  background: #fff8ef;
  color: #8b7468;
  font-size: 24rpx;
}

.album-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
}

.photo-card {
  overflow: hidden;
}

.photo {
  width: 100%;
  height: 220rpx;
  background: #ead9cc;
}

.info {
  padding: 16rpx;
}

.name {
  overflow: hidden;
  color: #4f3b31;
  font-size: 28rpx;
  font-weight: 700;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.date {
  margin-top: 6rpx;
  color: #a68b7d;
  font-size: 22rpx;
}

.empty {
  position: relative;
  padding: 70rpx 30rpx;
  text-align: center;
}

.empty-title {
  color: #5b4034;
  font-size: 32rpx;
  font-weight: 700;
}

.empty-desc {
  margin-top: 12rpx;
  color: #9a8173;
  font-size: 25rpx;
}
