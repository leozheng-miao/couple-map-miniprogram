.airmail {
  padding: 28rpx;
  border: 10rpx solid transparent;
  border-image: repeating-linear-gradient(45deg, #e86a5f 0 18rpx, #fff9f0 18rpx 34rpx, #7fa7c6 34rpx 52rpx, #fff9f0 52rpx 68rpx) 10;
}

.photos {
  display: flex;
  gap: 12rpx;
  overflow-x: auto;
  margin-bottom: 24rpx;
}

.upload,
.thumb,
.photo-item {
  flex: none;
  width: 148rpx;
  height: 148rpx;
  border-radius: 16rpx;
}

.upload {
  display: flex;
  align-items: center;
  justify-content: center;
  border: 1rpx dashed #d7b99a;
  background: #fff8ef;
  color: #a68b7d;
  font-size: 23rpx;
  line-height: 1.35;
  text-align: center;
}

.photo-item {
  position: relative;
  overflow: hidden;
  background: #ead9cc;
}

.thumb {
  display: block;
  width: 100%;
  height: 100%;
}

.cover-badge {
  position: absolute;
  top: 8rpx;
  left: 8rpx;
  padding: 4rpx 10rpx;
  border-radius: 999rpx;
  background: rgba(233, 75, 67, 0.92);
  color: #fff;
  font-size: 20rpx;
  line-height: 1.3;
}

.photo-actions {
  position: absolute;
  right: 0;
  bottom: 0;
  left: 0;
  display: grid;
  grid-template-columns: 1fr 1fr;
  background: rgba(79, 59, 49, 0.72);
}

.photo-action {
  height: 42rpx;
  color: #fff;
  font-size: 20rpx;
  line-height: 42rpx;
  text-align: center;
}

.photo-action.danger {
  color: #ffd8d5;
}

.field {
  margin-bottom: 24rpx;
}

.label {
  margin-bottom: 10rpx;
  color: #7c6254;
  font-size: 24rpx;
  font-weight: 700;
}

.input,
.textarea {
  width: 100%;
  border-radius: 14rpx;
  background: #f4eadc;
  color: #4f3b31;
  font-size: 28rpx;
}

.input {
  height: 76rpx;
  padding: 0 20rpx;
}

.textarea {
  min-height: 170rpx;
  padding: 18rpx 20rpx;
  line-height: 1.5;
}

.chips {
  display: flex;
  gap: 14rpx;
  flex-wrap: wrap;
}

.chip {
  padding: 12rpx 22rpx;
  border-radius: 999rpx;
  background: #f5eadc;
  color: #7d5f50;
  font-size: 24rpx;
}

.chip.active {
  background: #e94b43;
  color: #fff;
}

.location-row {
  display: flex;
  gap: 12rpx;
}

.location {
  flex: 1;
}

.icon-btn {
  width: 76rpx;
  height: 76rpx;
  border-radius: 50%;
  background: #fff8ef;
  color: #7d5f50;
  font-size: 24rpx;
  line-height: 76rpx;
  text-align: center;
}

.two {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 18rpx;
}

.picker {
  line-height: 76rpx;
}

.rating {
  color: #e94b43;
  font-size: 24rpx;
}

.counter {
  margin-top: 8rpx;
  color: #a68b7d;
  font-size: 22rpx;
  text-align: right;
}
