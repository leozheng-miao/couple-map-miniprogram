.profile {
  display: flex;
  align-items: center;
  gap: 24rpx;
  padding: 28rpx;
  margin-bottom: 24rpx;
}

.avatar {
  width: 112rpx;
  height: 112rpx;
  border: 6rpx solid #fff;
  border-radius: 50%;
  background: #ead9cc;
}

.profile-main {
  flex: 1;
  min-width: 0;
}

.name,
.name-input {
  color: #4f3b31;
  font-size: 34rpx;
  font-weight: 800;
}

.profile-input {
  width: 100%;
  height: 52rpx;
  padding: 0;
  background: transparent;
}

.avatar-button {
  flex: none;
  width: 96rpx;
  height: 52rpx;
  margin: 0;
  padding: 0;
  border-radius: 999rpx;
  background: #fff8ef;
  color: #8b7468;
  font-size: 22rpx;
  line-height: 52rpx;
  text-align: center;
}

.avatar-button.disabled {
  opacity: 0.64;
}

.meta {
  margin-top: 10rpx;
  color: #d65e59;
  font-size: 24rpx;
}

.space,
.menu {
  padding: 28rpx;
  margin-bottom: 24rpx;
}

.space-name,
.space-name-input {
  margin-top: 18rpx;
  padding: 24rpx;
  border-radius: 16rpx;
  background: #fff5e7;
  color: #5b4034;
  font-size: 30rpx;
  font-weight: 700;
}

.space-name-input {
  box-sizing: border-box;
  width: 100%;
  height: 92rpx;
}

.line {
  margin-top: 18rpx;
  color: #8b7468;
  font-size: 26rpx;
}

.invite-actions {
  display: flex;
  gap: 16rpx;
  align-items: center;
  flex-wrap: wrap;
  margin-top: 24rpx;
}

.action-button {
  width: auto;
  min-width: 168rpx;
  height: 64rpx;
  margin: 0;
  padding: 0 24rpx;
  border-radius: 999rpx;
  font-size: 24rpx;
  line-height: 64rpx;
}

.action-button::after {
  border: 0;
}

.save-profile {
  margin-top: 24rpx;
}

.menu-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  min-height: 88rpx;
  border-bottom: 1rpx solid #f0e3d6;
  color: #5b4034;
  font-size: 28rpx;
}

.menu-item:last-child {
  border-bottom: 0;
}

.menu-item text {
  color: #a68b7d;
  font-size: 24rpx;
}
