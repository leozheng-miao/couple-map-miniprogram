.profile {
  display: flex;
  align-items: center;
  gap: 24rpx;
  padding: 28rpx;
  margin-bottom: 24rpx;
}

.avatar {
  width: 112rpx;
  height: 112rpx;
  border: 6rpx solid #fff;
  border-radius: 50%;
  background: #ead9cc;
}

.profile-main {
  flex: 1;
}

.name {
  color: #4f3b31;
  font-size: 34rpx;
  font-weight: 800;
}

.meta {
  margin-top: 10rpx;
  color: #d65e59;
  font-size: 24rpx;
}

.space,
.menu {
  padding: 28rpx;
  margin-bottom: 24rpx;
}

.space-name {
  margin-top: 18rpx;
  padding: 24rpx;
  border-radius: 16rpx;
  background: #fff5e7;
  color: #5b4034;
  font-size: 30rpx;
  font-weight: 700;
}

.line {
  margin-top: 18rpx;
  color: #8b7468;
  font-size: 26rpx;
}

.buttons {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
  margin-top: 24rpx;
}

.menu-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  min-height: 88rpx;
  border-bottom: 1rpx solid #f0e3d6;
  color: #5b4034;
  font-size: 28rpx;
}

.menu-item:last-child {
  border-bottom: 0;
}

.menu-item text {
  color: #a68b7d;
  font-size: 24rpx;
}
