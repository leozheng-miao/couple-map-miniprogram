<view class="safe-page">
  <view class="profile paper-card">
    <image class="avatar" src="{{profileForm.avatarUrl || user.avatarUrl || '/assets/theme/design-theme-reference.png'}}" mode="aspectFill" bindtap="onChooseAvatar"></image>
    <view class="profile-main">
      <input class="profile-input name-input" value="{{profileForm.nickName}}" maxlength="24" data-field="nickName" bindinput="onProfileInput" placeholder="我的名字" />
      <view class="meta">甜蜜值 {{placesCount}}</view>
    </view>
    <view class="avatar-button {{uploadingAvatar ? 'disabled' : ''}}" bindtap="onChooseAvatar">{{uploadingAvatar ? '上传中' : '换头像'}}</view>
  </view>

  <view class="space paper-card">
    <view class="section-title">我们的空间</view>
    <input class="space-name-input" value="{{profileForm.spaceName}}" maxlength="24" data-field="spaceName" bindinput="onProfileInput" placeholder="空间名称" />
    <view class="line">成员：{{memberCount}} / 2</view>
    <view wx:if="{{canInvite}}" class="line">邀请码：{{space.inviteCode || '-'}}</view>
    <view wx:if="{{canInvite}}" class="invite-actions">
      <button class="secondary-button action-button" bindtap="onCopyInvite">复制邀请码</button>
      <button class="secondary-button action-button" bindtap="onRefreshInvite">刷新邀请码</button>
    </view>
    <button class="primary-button save-profile" loading="{{savingProfile}}" disabled="{{savingProfile}}" bindtap="onSaveProfile">保存资料</button>
  </view>

  <view class="menu paper-card">
    <view class="menu-item">我们去过的地方 <text>{{placesCount}} 个地点</text></view>
    <view class="menu-item">便利贴 <text>{{notesCount}} 张</text></view>
    <view class="menu-item" bindtap="onExport">旅行手账 <text>导出</text></view>
    <view class="menu-item">设置 <text>云环境与地图 Key</text></view>
  </view>
</view>
