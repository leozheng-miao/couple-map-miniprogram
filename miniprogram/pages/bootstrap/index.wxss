.bootstrap {
  padding-top: 56rpx;
}

.hero {
  position: relative;
  padding: 54rpx 34rpx 34rpx;
  text-align: center;
}

.tape {
  position: absolute;
  width: 90rpx;
  height: 36rpx;
  border-radius: 4rpx;
  background: rgba(199, 160, 112, 0.42);
}

.tape-left {
  top: 28rpx;
  left: 20rpx;
  transform: rotate(-26deg);
}

.tape-right {
  top: 180rpx;
  right: 28rpx;
  transform: rotate(23deg);
}

.title {
  color: #4b3124;
  font-size: 66rpx;
  font-weight: 800;
  letter-spacing: 0;
}

.heart {
  color: #e94b43;
}

.subtitle {
  margin-top: 12rpx;
  color: #8b7468;
  font-size: 26rpx;
}

.badge {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  margin-top: 26rpx;
  padding: 12rpx 36rpx;
  border-radius: 8rpx;
  background: #e96d6b;
  color: #fff;
  font-size: 28rpx;
  font-weight: 700;
}

.theme {
  display: block;
  width: 520rpx;
  height: 360rpx;
  margin: 34rpx auto 0;
  border: 12rpx solid #fffdf9;
  border-radius: 8rpx;
  box-shadow: 0 12rpx 26rpx rgba(91, 62, 44, 0.18);
}

.copy {
  margin-top: 28rpx;
  color: #6f5548;
  font-size: 28rpx;
  line-height: 1.6;
}

.actions {
  display: grid;
  gap: 20rpx;
  margin-top: 30rpx;
}

.join {
  margin-top: 26rpx;
  padding: 26rpx;
}

.input {
  height: 82rpx;
  margin: 22rpx 0;
  padding: 0 24rpx;
  border-radius: 16rpx;
  background: #f5eadc;
  color: #4f3b31;
  font-size: 30rpx;
}

.terms {
  margin-top: 26rpx;
  color: #b19788;
  font-size: 22rpx;
  text-align: center;
}
